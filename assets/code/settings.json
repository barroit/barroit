{
   /* -------------------------------  Window  -------------------------------- */
   "workbench.activityBar.location": "top",
   "window.restoreWindows": "none",
   "window.zoomLevel": 4,
   "explorer.autoReveal": false,
   /* -------------------------------  Editor  -------------------------------- */
   "workbench.editor.doubleClickTabToToggleEditorGroupSizes": "off",
   "workbench.editor.enablePreview": false,
   "workbench.editor.editorActionsLocation": "hidden",
   "diffEditor.renderSideBySide": false,
   "merge-conflict.decorators.enabled": false,
   "editor.stickyScroll.enabled": false,
   "editor.minimap.enabled": false,
   "editor.scrollbar.horizontal": "hidden",
   "problems.visibility": false,
   /* -----------------------------  Suggestion  ------------------------------ */
   "editor.codeLens": false,
   "editor.guides.indentation": false,
   "editor.quickSuggestions": {
      "other": "off"
   },
   "editor.suggestOnTriggerCharacters": false,
   "explorer.confirmPasteNative": false,
   "explorer.confirmDragAndDrop": false,
   "explorer.confirmDelete": false,
   "extensions.ignoreRecommendations": true,
   "typescript.validate.enable": false,
   "javascript.validate.enable": false,
   /* ---------------------------  Source Control  ---------------------------- */
   "scm.showActionButton": false,
   "git.showCommitInput": false,
   "git.openRepositoryInParentFolders": "never",
   "git.mergeEditor": true,
   /* ------------------------------  Highlight  ------------------------------ */
   "editor.occurrencesHighlight": "off",
   "editor.selectionHighlight": false,
   "editor.matchBrackets": "never",
   "editor.unicodeHighlight.includeStrings": false,
   "C_Cpp.dimInactiveRegions": false,
   /* --------------------------------  Save  --------------------------------- */
   "files.autoSave": "onFocusChange",
   "files.insertFinalNewline": true,
   /* -----------------------------  Indentation  ----------------------------- */
   "editor.autoIndent": "brackets",
   "editor.detectIndentation": false,
   "editor.insertSpaces": false,
   "editor.tabSize": 8,
   "[cmake]": {
      "editor.insertSpaces": true,
      "editor.indentSize": 2
   },
   "[jsonc]": {
      "editor.insertSpaces": true,
      "editor.tabSize": 3
   },
   "[json]": {
      "editor.insertSpaces": true,
      "editor.tabSize": 3
   },
   "[xml]": {
      "editor.insertSpaces": true,
      "editor.indentSize": 2
   },
   "[markdown]": {
      "editor.wordWrap": "off"
   },
   "[yaml]": {
      "editor.tabSize": 3
   },
   "[html]": {
      "editor.insertSpaces": true,
      "editor.tabSize": 2
   },
   /* -------------------------  File Header Comment  ------------------------- */
   "fileHeaderComment.template": {
      "*": [
         "# SPDX-License-Identifier: ${license}"
      ],
      "bash": [
         "#!/bin/bash",
         "# SPDX-License-Identifier: ${license}"
      ],
      "c": [
         "// SPDX-License-Identifier: ${license}",
         "/*",
         " * Copyright ${year} Jiamu Sun <barroit@linux.com>",
         " */"
      ],
      "h": [
         "/* SPDX-License-Identifier: ${license} */",
         "/*",
         " * Copyright ${year} Jiamu Sun <barroit@linux.com>",
         " */"
      ],
      "python": [
         "#!/usr/bin/python3",
         "# SPDX-License-Identifier: ${license}"
      ],
      "sh": [
         "#!/bin/sh",
         "# SPDX-License-Identifier: ${license}"
      ],
      "zsh": [
         "#!/bin/zsh",
         "# SPDX-License-Identifier: ${license}"
      ],
      "rst": [
         ".. SPDX-License-Identifier: ${license}"
      ],
      "html": [
         "<!-- ============================",
         "SPDX-License-Identifier: ${license}",
         "",
         "Copyright ${year} Jiamu Sun <barroit@linux.com>",
         "============================= -->"
      ]
   },
   /* ------------------------------  CodeSnap  ------------------------------- */
   "codesnap.showWindowControls": false,
   "codesnap.realLineNumbers": true,
   "codesnap.roundedCorners": false,
   "codesnap.shutterAction": "copy",
   "codesnap.containerPadding": "0",
   /* --------------------------------  Misc  --------------------------------- */
   "cmake.configureOnOpen": false,
   /* -----------------------------  Association  ----------------------------- */
   "C_Cpp.autoAddFileAssociations": false,
   "files.associations": {
      "*gdbinit": "plaintext",
      "README*": "plaintext",
      "Kconfig": "plaintext",
      "TODO": "plaintext",
      ".git*": "plaintext",
      ".muttrc": "plaintext",
      ".config*": "plaintext",
      "*.h.in": "c",
      "*.hpp.in": "cpp",
      "settings.json": "jsonc"
   },
   /* --------------------------------  Font  --------------------------------- */
   "editor.fontFamily": "'JetBrains Mono'",
   "editor.fontSize": 19,
   /* ----------------------------  Color Scheme  ----------------------------- */
   "workbench.colorTheme": "Default Dark Modern",
   "C_Cpp.enhancedColorization": "disabled",
   "workbench.colorCustomizations": {
      "editorBracketHighlight.foreground1": "#A8A8A8",
      "editorBracketHighlight.foreground2": "#A8A8A8",
      "editorBracketHighlight.foreground3": "#A8A8A8",
      "editorBracketHighlight.foreground4": "#A8A8A8",
      "editorBracketHighlight.foreground5": "#A8A8A8",
      "editorBracketHighlight.foreground6": "#A8A8A8",
      "editor.foreground": "#A8A8A8",
      "editor.background": "#141414",
      "diffEditor.removedLineBackground": "#500000a0",
      "diffEditor.insertedLineBackground": "#2b3f14fa",
      "diffEditor.insertedTextBackground": "#0000"
   },
   "editor.tokenColorCustomizations": {
      "textMateRules": [
         {
            "settings": {
               "foreground": "#CE9178"
            },
            "scope": [
               "constant.other.placeholder"
            ]
         },
         {
            "settings": {
               "foreground": "#C6C699"
            },
            "scope": [
               "entity.name.function",
               "support.function.builtin"
            ]
         },
         {
            "settings": {
               "foreground": "#569CD6"
            },
            "scope": [
               "entity.name.tag.css",
               "entity.name.tag.js.jsx",
               "entity.other.attribute-name.class.css",
               "entity.other.attribute-name.id.css",
               "entity.other.attribute-name.pseudo-element.css",
               "keyword.control",
               "keyword.operator.delete",
               "keyword.operator.new.cpp",
               "keyword.other.directive.using.cs",
               "keyword.other.operator.overload",
               "keyword.other.using.directive",
               "storage.modifier",
               "storage.type.built-in.primitive",
               "storage.type.primitive.java",
               "support.class.component.js.jsx",
               "support.type.built-in.posix-reserved",
               "support.type.posix-reserved"
            ]
         },
         {
            "settings": {
               "foreground": "#A8A8A8"
            },
            "scope": [
               "comment",
               "constant.character.escape",
               "constant.character.set.regexp",
               "constant.language",
               "constant.other.character-class.regexp",
               "constant.other.color.rgb-value.hex.css",
               "constant.other.php",
               "constant.other.set.regexp",
               "entity.name.function",
               "entity.name.function.preprocessor",
               "entity.name.label",
               "entity.name.label.call",
               "entity.name.namespace",
               "entity.name.operator.type",
               "entity.name.other.preprocessor.macro.predefined",
               "entity.name.scope-resolution",
               "entity.name.type",
               "entity.name.variable.field.cs",
               "entity.name.variable.local.cs",
               "entity.other.attribute",
               "entity.other.attribute-name",
               "entity.other.attribute-name.pseudo-class.css",
               "interpolated.complex.source.powershell",
               "keyword.control.directive",
               "keyword.control.directive",
               "keyword.operator",
               "keyword.operator.quantifier.regexp",
               "meta.parameters.js",
               "meta.preprocessor.macro",
               "punctuation.accessor.cs",
               "punctuation.accessor.js",
               "punctuation.accessor.tsx",
               "punctuation.definition.template-expression.begin.js",
               "punctuation.definition.template-expression.end.js",
               "punctuation.parenthesis.begin.regexp",
               "punctuation.parenthesis.end.regexp",
               "punctuation.separator.comma.js",
               "punctuation.separator.comma.tsx",
               "punctuation.separator.delimiter.php",
               "punctuation.separator.key-value.js",
               "punctuation.separator.key-value.ts",
               "punctuation.separator.key-value.tsx",
               "punctuation.terminator.expression.php",
               "punctuation.terminator.statement.js",
               "storage.modifier.import.java",
               "storage.modifier.pointer",
               "storage.modifier.reference",
               "storage.source.cmake",
               "storage.type.annotation.java",
               "storage.type.function.arrow.js",
               "storage.type.function.arrow.ts",
               "storage.type.generic.java",
               "storage.type.java",
               "string.regexp",
               "support.class",
               "support.constant.property-value.css",
               "support.function.attribute.powershell",
               "support.function.builtin",
               "support.function.construct.php",
               "support.function.js",
               "support.function.misc.css",
               "support.function.powershell",
               "support.function.target.PHONY.makefile",
               "support.function.ts",
               "support.function.tsx",
               "support.type",
               "support.type.object.module.js",
               "support.type.primitive.ts",
               "support.type.property-name.css",
               "support.type.property-name.json.comments",
               "support.type.python",
               "support.variable.automatic.powershell",
               "support.variable.drive.powershell",
               "support.variable.js",
               "support.variable.magic.python",
               "support.variable.property",
               "support.variable.ts",
               "support.variable.tsx",
               "variable",
               "variable.legacy.builtin.python",
               "variable.other.constant",
               "variable.other.enummember",
               "variable.other.member.powershell"
            ]
         },
         {
            "settings": {
               "foreground": "#ACC4A0"
            },
            "scope": [
               "constant.numeric.decimal",
               "constant.numeric.integer",
               "storage.type.number.python"
            ]
         }
      ]
   },
   "security.workspace.trust.untrustedFiles": "open",
   "workbench.navigationControl.enabled": false,
   "window.commandCenter": false,
   "window.menuBarVisibility": "hidden",
   "workbench.layoutControl.enabled": false,
   "chat.commandCenter.enabled": false,
   "workbench.startupEditor": "none",
   "workbench.editor.empty.hint": "hidden",
   "xml.symbols.maxItemsComputed": -1,
   "editor.unicodeHighlight.ambiguousCharacters": false
}
